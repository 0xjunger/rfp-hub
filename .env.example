# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Redis (for rate limiting)
REDIS_URL=redis://default:password@host:port

# API URL (used by web app to reach the API)
API_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=https://rfp-hub-api.fly.dev

# Docs URL (used in web app header/footer links)
NEXT_PUBLIC_DOCS_URL=https://rfp-hub-api.fly.dev/api/v1/openapi

# Port (defaults handled by each app)
# PORT=3000
